PORT=3001
FRONTEND_URL=http://localhost:3002
NODE_ENV=development

# ---- Email sending -------------------------------------------------------
# Option A (recommended for testing): any SMTP provider (Mailtrap, Gmail,
# Brevo, Resend, SendGrid SMTP…). SMTP takes precedence when set.
#   Mailtrap sandbox example: host sandbox.smtp.mailtrap.io, port 2525
SMTP_HOST=
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
# SMTP_SECURE=false   # optional; defaults to true only on port 465

# Option B: SendGrid API (used only if SMTP_* is not set). Must start with "SG."
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Sender identity used by both options
FROM_EMAIL=your-verified-sender@example.com
FROM_NAME=Clinical Trials Research

# Signs one-click unsubscribe links — set to any long random string in production
UNSUBSCRIBE_SECRET=
# Public app URL used to build unsubscribe links (defaults to FRONTEND_URL)
# PUBLIC_URL=https://app.example.com

# --- Accounts / auth ---
# If set, new signups must supply this exact code (a lightweight gate so random
# visitors can't self-register). Leave blank to allow open registration.
SIGNUP_CODE=

# Twilio Configuration (for SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Anthropic (Claude) API — powers AI outreach/sequence generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Hunter.io — optional, for verified contact email enrichment
HUNTER_API_KEY=your_hunter_api_key_here
